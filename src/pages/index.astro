---
const features = [
  {
    eyebrow: "Credential flexibility",
    title: "Token and certificate workflows in one desktop tool",
    description:
      "Novel Signer supports PKCS#11 hardware tokens and P12 or PFX certificates so regulated signing flows do not need separate utilities.",
  },
  {
    eyebrow: "Placement control",
    title: "Visible signatures with precise preview",
    description:
      "Review page placement, signature dimensions, and appearance before the file is signed and distributed.",
  },
  {
    eyebrow: "Throughput",
    title: "Single, multi-file, and directory signing",
    description:
      "Handle one document or a whole working set with progress visibility, structured output, and clear failure reporting.",
  },
];

const workflow = [
  {
    step: "01",
    title: "Connect the credential",
    description: "Use a USB token or load a certificate file, then validate access directly from the signing workspace.",
  },
  {
    step: "02",
    title: "Choose the source PDFs",
    description: "Sign one file, a selected batch, or an entire directory depending on the volume of work.",
  },
  {
    step: "03",
    title: "Review and execute",
    description: "Set the visible signature, confirm the request, and export finished PDFs with trackable results.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Novel Signer | Desktop PDF Signing</title>
    <meta
      name="description"
      content="Novel Signer is a desktop PDF signing application with token support, certificate workflows, visible signature preview, and batch signing."
    />
  </head>
  <body>
    <main class="page-shell">
      <section class="hero">
        <div class="hero__glow hero__glow--amber"></div>
        <div class="hero__glow hero__glow--cyan"></div>
        <header class="hero__header">
          <div>
            <p class="brand">Novel Signer</p>
            <p class="brand-copy">
              Desktop PDF signing for contracts, approvals, and compliance workflows that need predictable output.
            </p>
          </div>
          <nav class="hero__actions">
            <a href="#capabilities" class="button button--secondary">Capabilities</a>
            <a href="#workflow" class="button button--primary">See workflow</a>
          </nav>
        </header>

        <div class="hero__content">
          <div class="hero__copy">
            <p class="eyebrow">Secure PDF execution</p>
            <h1>Sign regulated PDF workflows without the usual desktop friction.</h1>
            <p class="lede">
              Novel Signer combines hardware token support, certificate-based signing, visible signature preview, and
              batch processing in one focused desktop application.
            </p>

            <div class="hero__stats">
              <article>
                <strong>3 signing modes</strong>
                <span>Single file, multi-file, or directory execution.</span>
              </article>
              <article>
                <strong>Preview before export</strong>
                <span>Review placement and signature appearance in-app.</span>
              </article>
              <article>
                <strong>Batch result tracking</strong>
                <span>See success, skip, and failure states clearly.</span>
              </article>
            </div>
          </div>

          <aside class="workflow-card" id="workflow">
            <p class="workflow-card__eyebrow">Workflow snapshot</p>
            <div class="workflow-card__steps">
              {workflow.map((item) => (
                <article class="workflow-card__step">
                  <span>{item.step}</span>
                  <div>
                    <h2>{item.title}</h2>
                    <p>{item.description}</p>
                  </div>
                </article>
              ))}
            </div>
            <div class="workflow-card__footer">
              <p class="workflow-card__label">Best fit</p>
              <p>Teams handling repeated signing work across desktop environments with token-backed credentials.</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="capabilities" id="capabilities">
        {features.map((feature) => (
          <article class="capability-card">
            <p>{feature.eyebrow}</p>
            <h2>{feature.title}</h2>
            <p>{feature.description}</p>
          </article>
        ))}
      </section>

      <section class="closing-panel">
        <div>
          <p class="eyebrow eyebrow--muted">Novel Signer</p>
          <h2>Built for teams that need signing to be repeatable, controlled, and fast to operate.</h2>
        </div>
        <a href="#top" class="button button--primary">Back to top</a>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f8f7f2;
    --surface: rgba(255, 255, 255, 0.82);
    --surface-strong: #0f172a;
    --text: #0f172a;
    --muted: #475569;
    --border: rgba(148, 163, 184, 0.28);
    --amber: #f59e0b;
    --cyan: #06b6d4;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    font-family: "Avenir Next", Avenir, "Segoe UI", sans-serif;
    color: var(--text);
    background:
