      linear-gradient(90deg, rgba(148, 163, 184, 0.12) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.7), transparent 92%);
    pointer-events: none;
  }

  .hero__glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(16px);
    opacity: 0.75;
