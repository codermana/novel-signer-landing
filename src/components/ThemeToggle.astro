<button
  id="theme-toggle"
  class="p-2 rounded-lg bg-white/50 dark:bg-slate-800/50 border border-slate-200 dark:border-slate-700 hover:bg-white/80 dark:hover:bg-slate-800/80 transition-all duration-200 backdrop-blur-sm cursor-pointer z-50 relative"
  type="button"
  aria-label="Toggle theme"
  aria-pressed="false"
>
